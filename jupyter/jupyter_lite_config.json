{
    "LiteTaskApp": {
        "force": true
    },
    "LiteBuildConfig": {
        "apps": [
            "tree",
            "notebooks"
        ],
        "lite_dir": ".",
        "contents": [
            "."
        ],
        "output_dir": "./dist",
        "base_url": "/jupyter/",
        "ignore_contents": [
            "\\.venv",
            "dist"
        ],
        "extra_ignore_contents": [
            "\\.md$",
            "\\.pdf$",
            "\\.png$",
            "\\.venv",
            "dist"
        ],
        "no_sourcemaps": true,
        "no_unused_shared_packages": true
    }
}